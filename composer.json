{
  "name": "bugo/sass-embedded-php",
  "description": "A lightweight PHP bridge for native Dart Sass",
  "type": "composer-plugin",
  "license": "MIT",
  "authors": [
    {
      "name": "Bugo",
      "email": "bugo@dragomano.ru"
    }
  ],
  "keywords": [
    "scss php",
    "sass php",
    "scss compiler",
    "sass compiler",
    "dart sass"
  ],
  "require": {
    "php": "^8.2",
    "composer-plugin-api": "^2.0",
    "symfony/process": "^7.4|^8.0",
    "ext-zip": "*"
  },
  "require-dev": {
    "bugo/scss-benchmark-utils": "dev-main",
    "composer/composer": "*",
    "friendsofphp/php-cs-fixer": "^3.94",
    "mockery/mockery": "dev-bugfix/spy-generics",
    "pestphp/pest": "^3.8|^4.4",
    "rector/rector": "^2.3",
    "scssphp/scssphp": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "Bugo\\Sass\\": "src/"
    }
  },
  "scripts": {
    "install-binary": "Bugo\\Sass\\Plugin::installBinary",
    "post-install-cmd": "@install-binary",
    "post-update-cmd": "@install-binary",
    "fix": "vendor/bin/php-cs-fixer fix",
    "check": "vendor/bin/rector process --dry-run --clear-cache",
    "rector": "vendor/bin/rector process",
    "benchmark": "php benchmark.php",
    "test": "vendor/bin/pest --colors=always",
    "test-coverage": "vendor/bin/pest --colors=always --coverage --min=100",
    "test-coverage-clover": "vendor/bin/pest --colors=always --min=100 --coverage-clover coverage.xml",
    "test-coverage-html": "vendor/bin/pest --colors=always --min=100 --coverage-html coverage"
  },
  "extra": {
    "class": "Bugo\\Sass\\Plugin"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
